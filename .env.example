# ── Base de datos (Supabase / Postgres) ──
DATABASE_URL=postgresql://usuario:password@host:5432/postgres

# ── Autenticación ──
JWT_SECRET=cambiar-por-un-secreto-largo
# Opcionales:
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
# JWT_REFRESH_SECRET=

# ── IA (Gemini) ──
GEMINI_API_KEY=tu-api-key-de-gemini

# ── Notificaciones por email (Brevo) ──
# Sin BREVO_API_KEY el envío queda desactivado (no rompe nada, sólo no manda mails).
BREVO_API_KEY=xkeysib-...
# Remitente: debe ser un email verificado en Brevo (Senders & IP).
EMAIL_FROM=notificaciones@tu-dominio.com
EMAIL_FROM_NAME=NEXIA
# URL del frontend, usada en los botones de los emails.
APP_URL=http://localhost:5173

# ── Servidor ──
# PORT=3000
